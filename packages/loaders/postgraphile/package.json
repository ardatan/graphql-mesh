{
  "name": "@omnigraph/postgraphile",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "ardatan/graphql-mesh",
    "directory": "packages/loaders/postgraphile"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/typings/index.d.cts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "default": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typings": "dist/typings/index.d.ts",
  "peerDependencies": {
    "graphql": "*"
  },
  "dependencies": {
    "@dataplan/pg": "^1.0.0-rc.0",
    "@graphql-mesh/transport-postgraphile": "^0.1.0",
    "@graphql-mesh/types": "^0.104.25",
    "@graphql-tools/delegate": "^12.0.12",
    "pg": "^8.20.0",
    "postgraphile": "^5.0.0-rc.0",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "graphql": "16.13.1"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "sideEffects": false,
  "typescript": {
    "definition": "dist/typings/index.d.ts"
  }
}
