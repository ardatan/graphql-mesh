{
  "name": "@graphql-mesh/transport-soap",
  "version": "0.10.43",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "ardatan/graphql-mesh",
    "directory": "packages/transports/soap"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/typings/index.d.cts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "default": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typings": "dist/typings/index.d.ts",
  "peerDependencies": {
    "graphql": "*"
  },
  "dependencies": {
    "@graphql-mesh/cross-helpers": "^0.4.13",
    "@graphql-mesh/string-interpolation": "^0.5.16",
    "@graphql-mesh/transport-common": "^1.0.16",
    "@graphql-mesh/types": "^0.104.27",
    "@graphql-mesh/utils": "^0.104.35",
    "@graphql-tools/executor": "^1.5.2",
    "@graphql-tools/utils": "^11.0.1",
    "@whatwg-node/fetch": "^0.10.6",
    "fast-xml-parser": "^5.6.0",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "graphql": "16.13.2"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "sideEffects": false,
  "typescript": {
    "definition": "dist/typings/index.d.ts"
  }
}
