{
  "name": "@graphql-mesh/incontext-sdk-codegen",
  "version": "0.0.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "ardatan/graphql-mesh",
    "directory": "packages/incontext-sdk-codegen"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/typings/index.d.cts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "default": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typings": "dist/typings/index.d.ts",
  "peerDependencies": {
    "graphql": "*"
  },
  "dependencies": {
    "@graphql-codegen/core": "^5.0.1",
    "@graphql-codegen/plugin-helpers": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-mesh/cross-helpers": "^0.4.12",
    "@graphql-mesh/fusion-runtime": "^1.7.0",
    "@graphql-mesh/transport-common": "^1.0.15",
    "@graphql-mesh/types": "^0.104.23",
    "@graphql-mesh/utils": "^0.104.25",
    "@graphql-tools/utils": "^11.0.0",
    "@graphql-tools/wrap": "^11.1.9",
    "graphql-scalars": "^1.25.0",
    "pascal-case": "^3.1.2",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "graphql": "16.13.1"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "sideEffects": false,
  "typescript": {
    "definition": "dist/typings/index.d.ts"
  }
}
