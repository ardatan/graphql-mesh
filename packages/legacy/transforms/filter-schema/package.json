{
  "name": "@graphql-mesh/transform-filter-schema",
  "version": "0.104.38",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "ardatan/graphql-mesh",
    "directory": "packages/legacy/transforms/filter-schema"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/typings/index.d.cts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "default": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typings": "dist/typings/index.d.ts",
  "peerDependencies": {
    "graphql": "*"
  },
  "dependencies": {
    "@graphql-mesh/types": "^0.104.29",
    "@graphql-mesh/utils": "^0.104.37",
    "@graphql-tools/delegate": "12.1.0-alpha-cf04a323a695c2668e4b2edf5e8755dafaf41e8f",
    "@graphql-tools/utils": "^11.2.0",
    "@graphql-tools/wrap": "^11.1.18",
    "minimatch": "^10.2.5",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "@types/minimatch": "6.0.0",
    "graphql": "16.14.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "sideEffects": false,
  "typescript": {
    "definition": "dist/typings/index.d.ts"
  }
}
