{
  "name": "@graphql-mesh/transform-rate-limit",
  "version": "0.105.40",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "ardatan/graphql-mesh",
    "directory": "packages/legacy/transforms/rate-limit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/typings/index.d.cts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "default": {
        "types": "./dist/typings/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typings": "dist/typings/index.d.ts",
  "peerDependencies": {
    "graphql": "*"
  },
  "dependencies": {
    "@graphql-mesh/cross-helpers": "^0.4.15",
    "@graphql-mesh/string-interpolation": "^0.5.18",
    "@graphql-mesh/types": "^0.104.30",
    "@graphql-mesh/utils": "^0.104.38",
    "@graphql-tools/utils": "^11.2.0",
    "minimatch": "^10.2.5",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "@graphql-mesh/cache-localforage": "0.105.39",
    "@graphql-tools/schema": "10.0.36",
    "@graphql-tools/wrap": "^11.1.18",
    "graphql": "16.14.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "sideEffects": false,
  "typescript": {
    "definition": "dist/typings/index.d.ts"
  }
}
