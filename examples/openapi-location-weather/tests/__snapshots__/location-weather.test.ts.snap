    """Your registered API key."""
    key: String
    lang: queryInput_history_hourly_lang

    """Latitude component of location."""
    lat: Float

    """Longitude component of location."""
    lon: Float

    """Postal Code. Example: 28546"""
    postal_code: String

    """Start Date (YYYY-MM-DD or YYYY-MM-DD:HH)."""
    start_date: String!

    """Station Call ID."""
    station: String
    tz: queryInput_history_hourly_tz
    units: queryInput_history_hourly_units
  ): history_hourly_response

  """Returns lightning data by lat/lon from a given date."""
  history_lightning(
    """Date to retrieve data for. (YYYY-MM-DD)"""
    date: String!

    """Your registered API key."""
