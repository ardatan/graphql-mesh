    """Limit result lightning. (Default 1500, Max 2500)"""
    limit: Int

    """Longitude component of location."""
    lon: Float!
    output_type: queryInput_history_lightning_output_type

    """Radial search distance from point in KM. (Default 20 KM - Max 75 KM)"""
    search_distance_km: Int

    """Number of results to skip in response. (Offset)"""
    skip: Int
    sort: queryInput_history_lightning_sort
    tz: queryInput_history_lightning_tz
  ): history_lightning_response

