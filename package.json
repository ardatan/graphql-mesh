{
  "name": "graphql-mesh",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "website",
      "packages/*",
      "packages/legacy/*",
      "packages/legacy/handlers/*",
      "packages/legacy/transforms/*",
      "packages/legacy/mergers/*",
      "packages/cache/*",
      "packages/plugins/*",
      "packages/fusion/*",
      "examples/*",
      "examples/integrations/*",
      "examples/federation-example/*",
      "examples/federation-example/services/*",
      "examples/graphql-file-upload-example/frontend",
      "examples/hive-example/gateway",
      "examples/hive-example/sources/*",
      "packages/loaders/*",
      "packages/transports/*",
      "examples/v1-next/*",
      "examples/v1-next/integrations/*",
      "examples/v1-next/federation-example/*",
      "examples/v1-next/federation-example/services/*",
      "examples/v1-next/graphql-file-upload-example/frontend",
      "examples/v1-next/hive-example/gateway",
      "examples/v1-next/hive-example/my-graphql",
      "examples/v1-next/hive-example/my-rest",
      "e2e/*"
    ]
  },
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "build": "yarn prebuild && bob build && yarn postbuild",
    "build-test-artifacts": "yarn workspace @examples/json-schema-example build && yarn workspace @examples-v1-next/fastify compose && yarn workspace @examples/fastify build && yarn workspace @examples/persisted-operations build && yarn workspace example-response-cache build && yarn workspace @examples/json-schema-complex-url build",
    "build:website": "yarn build && cd website && yarn build",
    "changeset": "changeset",
    "changeset-version": "changeset version && yarn postchangeset",
    "ci:lint": "eslint --output-file eslint_report.json --ext .ts --format json \"./packages/**/src/**/*.ts\"",
    "clean": "(rm -rf packages/**/(!node_modules)/**/dist & rm -rf examples/**/node_modules/.bin/*mesh* & rm -rf .bob) || true",
    "copy-config-schema": "cp-cli ./packages/legacy/types/src/config-schema.json ./packages/legacy/types/dist/esm/config-schema.json && cp-cli ./packages/legacy/types/src/config-schema.json ./packages/legacy/types/dist/cjs/config-schema.json",
    "dev:website": "yarn workspace website run dev",
    "fix-bin": "node scripts/fix-bin.js",
    "generate-config-schema": "rm -rf ./website/src/generated-markdown && yarn graphql-to-config-schema --schema ./**/yaml-config.graphql --json ./packages/legacy/types/src/config-schema.json --typings ./packages/legacy/types/src/config.ts --markdown ./website/src/generated-markdown && yarn postgenerate-config-schema",
    "inject-version": "yarn workspaces foreach -A run inject-version",
    "lint": "eslint --ext .ts \"./packages/**/src/**/*.ts\"",
    "package-binary": "yarn workspaces foreach -A run package-binary",
    "postbuild": "yarn inject-version && yarn copy-config-schema && yarn fix-bin && tsx scripts/replace-import-meta-url-in-cjs.ts",
    "postchangeset": "yarn install --no-immutable",
    "postgenerate-config-schema": "node scripts/create-config-schema-ts.js && npx prettier --write ./packages/legacy/types/src",
    "prebuild": "yarn clean && yarn generate-config-schema",
    "prettier": "prettier --write --list-different .",
    "prettier:check": "prettier --check .",
    "release": "yarn build && changeset publish",
    "test": "cross-env \"JEST=1\" jest --forceExit --no-watchman",
    "test:e2e": "cross-env \"JEST=1\" \"E2E_TEST=true\" jest --no-watchman --forceExit",
    "test:integration": "cross-env \"JEST=1\" \"INTEGRATION_TEST=true\" jest --forceExit --no-watchman",
    "test:integration:leak": "cross-env \"JEST=1\" \"LEAK_TEST=1\" \"INTEGRATION_TEST=true\" jest --detectOpenHandles --detectLeaks --no-watchman",
    "test:leak": "cross-env \"JEST=1\" \"LEAK_TEST=1\" jest --detectOpenHandles --detectLeaks --no-watchman",
    "test:website": "playwright test --config ./website/playwright.config.ts --retries 3",
    "typecheck": "yarn generate-config-schema && tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@ardatan/graphql-to-config-schema": "patch:@ardatan/graphql-to-config-schema@npm%3A0.1.25#~/.yarn/patches/@ardatan-graphql-to-config-schema-npm-0.1.25-f8c48d384e.patch",
    "@babel/core": "7.29.7",
    "@babel/parser": "7.29.7",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-explicit-resource-management": "7.27.4",
    "@babel/plugin-syntax-top-level-await": "7.14.5",
    "@babel/plugin-transform-class-static-block": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@babel/types": "7.29.7",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@eslint/eslintrc": "patch:@eslint/eslintrc@npm%3A3.3.3#~/.yarn/patches/@eslint-eslintrc-npm-3.3.3-8ccf6281a3.patch",
    "@repeaterjs/repeater": "^3.1.0",
    "@theguild/prettier-config": "3.0.1",
    "@tsconfig/node24": "^24.0.0",
    "@tsconfig/recommended": "^1.0.5",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "babel-jest": "30.4.1",
    "bob-the-bundler": "patch:bob-the-bundler@npm%3A7.0.1#~/.yarn/patches/bob-the-bundler-npm-7.0.1-ed23c34cf8.patch",
    "cp-cli": "^2.0.0",
    "cross-env": "^10.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-standard": "5.0.0",
    "globby": "11.1.0",
    "graphql": "16.14.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "16.4.0",
    "lru-cache": "11.2.6",
    "minimatch": "10.2.5",
    "node-gyp": "^12.3.0",
    "prettier": "3.8.4",
    "threads": "^1.7.0",
    "ts-jest": "29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "@changesets/assemble-release-plan": "patch:@changesets/assemble-release-plan@npm%3A5.2.3#~/.yarn/patches/@changesets-assemble-release-plan-npm-5.2.3-296454a28f.patch",
    "@changesets/get-github-info@npm:^0.8.0": "patch:@changesets/get-github-info@npm%3A0.8.0#~/.yarn/patches/@changesets-get-github-info-npm-0.8.0-cf3918dc5a.patch",
    "@opentelemetry/core": "^2.8.0",
    "@tootallnate/once": "3.0.1",
    "@whatwg-node/fetch": "0.10.13",
    "@whatwg-node/node-fetch": "0.8.5",
    "@whatwg-node/server": "0.11.0",
    "axios": "1.15.1",
    "body-parser": "2.2.2",
    "brace-expansion": "5.0.6",
    "cookie": "1.1.1",
    "cross-fetch": "^4.0.0",
    "date-and-time": "^4.0.0",
    "es5-ext": "0.10.64",
    "esbuild": "^0.28.1",
    "eslint": "10.5.0",
    "eslint-plugin-import": "patch:eslint-plugin-import@npm%3A2.32.0#~/.yarn/patches/eslint-plugin-import-npm-2.32.0-a1643bce9b.patch",
    "estree-util-value-to-estree": "3.5.0",
    "express": "5.2.1",
    "fast-xml-parser": ">=5.5.6",
    "form-data": "4.0.5",
    "graphql": "16.14.0",
    "graphql-jit": "patch:graphql-jit@npm%3A0.8.8#~/.yarn/patches/graphql-jit-npm-0.8.7-3ae882ba75.patch",
    "graphql-rate-limit": "patch:graphql-rate-limit@npm%3A3.3.0#~/.yarn/patches/graphql-rate-limit-npm-3.3.0-3ae882ba75.patch",
    "http-cache-semantics": "4.2.0",
    "immutable": "5.1.5",
    "ioredis-mock": "patch:ioredis-mock@npm%3A8.13.1#~/.yarn/patches/ioredis-mock-npm-8.13.1-a1a567479e.patch",
    "jest-leak-detector": "patch:jest-leak-detector@npm%3A29.7.0#~/.yarn/patches/jest-leak-detector-npm-29.7.0-3ae882ba75.patch",
    "jest-message-util": "patch:jest-message-util@npm%3A29.7.0#~/.yarn/patches/jest-message-util-npm-29.7.0-7f88b6e8d1.patch",
    "js-yaml": "4.3.0",
    "lodash": "4.18.0",
    "lodash-es": "4.18.0",
    "lru-cache": "patch:lru-cache@npm%3A11.2.6#~/.yarn/patches/lru-cache-npm-11.2.6-acb7d4323e.patch",
    "mermaid": "11.15.0",
    "minimatch": "10.2.5",
    "nextra": "patch:nextra@npm%3A3.2.5#~/.yarn/patches/nextra-npm-3.2.5-ab823bf5b2.patch",
    "node-fetch": "^2.6.7",
    "node-gyp": "^12.0.0",
    "nth-check": "^2.0.1",
    "on-headers": "1.1.0",
    "postcss": "^8.4.31",
    "protobufjs": "7.6.3",
    "rollup": "4.59.0",
    "sequelize": "6.37.8",
    "serialize-javascript": "7.0.3",
    "sha.js": "2.4.12",
    "sqlite3": "^5.1.7",
    "svgo": "2.8.1",
    "tar": "7.5.16",
    "tar-fs": "3.1.1",
    "tmp": "0.2.5",
    "tslib": "2.8.1",
    "underscore": "^1.12.1",
    "undici": "7.28.0",
    "uuid": "11.1.1",
    "validator": "^13.7.0",
    "webpack-dev-server": "5.2.4",
    "xml2js": "^0.6.0"
  },
  "lint-staged": {
    "packages/**/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{ts,tsx,graphql,yml,json,md,js,mjs,cjs,mdx}": [
      "prettier --write"
    ]
  }
}
