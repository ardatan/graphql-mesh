  import: ["@resolveTo", "@source", "@resolveRootField", "@httpOperation", "@transport", "@extraSchemaDefinitionDirective"]
)
  {
    query: Query
    
    
  }

  
    directive @join__enumValue(graph: join__Graph!) repeatable on ENUM_VALUE

