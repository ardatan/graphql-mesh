// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`should compose the appropriate schema 1`] = `
"schema
    @link(url: "https://specs.apollo.dev/link/v1.0")
    @link(url: "https://specs.apollo.dev/join/v0.3", for: EXECUTION)
    
    
    @link(url: "https://specs.apollo.dev/inaccessible/v0.2", for: SECURITY)
    
    
    
    @link(
  url: "https://the-guild.dev/graphql/mesh/spec/v1.0"
  import: ["@resolveTo", "@source"]
)
  {
    query: Query
    
    
  }

  
    directive @join__enumValue(graph: join__Graph!) repeatable on ENUM_VALUE

    directive @join__graph(name: String!, url: String!) on ENUM_VALUE

    
      directive @join__field(
        graph: join__Graph
        requires: join__FieldSet
        provides: join__FieldSet
        type: String
        external: Boolean
        override: String
        usedOverridden: Boolean
        
        
      ) repeatable on FIELD_DEFINITION | INPUT_FIELD_DEFINITION
    
    

    directive @join__implements(
      graph: join__Graph!
      interface: String!
    ) repeatable on OBJECT | INTERFACE

    directive @join__type(
      graph: join__Graph!
      key: join__FieldSet
      extension: Boolean! = false
      resolvable: Boolean! = true
      isInterfaceObject: Boolean! = false
    ) repeatable on OBJECT | INTERFACE | UNION | ENUM | INPUT_OBJECT | SCALAR

    directive @join__unionMember(
      graph: join__Graph!
      member: String!
    ) repeatable on UNION

    scalar join__FieldSet
    
  
  
  directive @link(
    url: String
    as: String
    for: link__Purpose
    import: [link__Import]
  ) repeatable on SCHEMA

  scalar link__Import

  enum link__Purpose {
    """
    \`SECURITY\` features provide metadata necessary to securely resolve fields.
    """
    SECURITY

    """
    \`EXECUTION\` features provide metadata necessary for operation execution.
    """
    EXECUTION
  }

  
  
  
  directive @inaccessible on FIELD_DEFINITION | OBJECT | INTERFACE | UNION | ENUM | ENUM_VALUE | SCALAR | INPUT_OBJECT | INPUT_FIELD_DEFINITION | ARGUMENT_DEFINITION

  
  
  
  
enum join__Graph {
  SUBGRAPH_A @join__graph(name: "subgraph-a", url: "http://localhost:<subgraph-a_port>/graphql") 
}

directive @resolveTo(
  additionalArgs: SubgraphAResolveToSourceArgs
  filterBy: String
  keyField: String
  keysArg: String
  pubsubTopic: String
  requiredSelectionSet: String
  result: String
  resultType: String
  sourceArgs: SubgraphAResolveToSourceArgs
  sourceFieldName: String
  sourceName: String
  sourceSelectionSet: String
  sourceTypeName: String
) on FIELD_DEFINITION

directive @source(name: String!, type: String, subgraph: String!)  repeatable on SCALAR | OBJECT | FIELD_DEFINITION | ARGUMENT_DEFINITION | INTERFACE | UNION | ENUM | ENUM_VALUE | INPUT_OBJECT | INPUT_FIELD_DEFINITION

scalar SubgraphAResolveToSourceArgs @join__type(graph: SUBGRAPH_A) 

type Query @join__type(graph: SUBGRAPH_A)  {
  _encapsulated_SubgraphA_foo(id: ID!) : SubgraphAFoo @source(name: "foo", type: "Foo", subgraph: "subgraph-a")  @inaccessible
  SubgraphA: SubgraphASubgraphAQuery! @resolveTo(
    sourceName: "subgraph-a"
    sourceTypeName: "Query"
    sourceFieldName: "__typename"
  )
}

type SubgraphAFoo @source(name: "Foo", subgraph: "subgraph-a")  @join__type(graph: SUBGRAPH_A)  {
  id: ID!
}

type SubgraphASubgraphAQuery @join__type(graph: SUBGRAPH_A)  {
  foo(id: ID!) : SubgraphAFoo @resolveTo(
    sourceName: "subgraph-a"
    sourceTypeName: "Query"
    sourceFieldName: "_encapsulated_SubgraphA_foo"
    sourceArgs: {id: "{args.id}"}
  )
}
"
`;

exports[`should execute Query foo 1`] = `
{
  "data": {
    "SubgraphA": {
      "foo": {
        "id": "123",
      },
    },
  },
}
`;
